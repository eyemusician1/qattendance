rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function validFullName(name) {
      return name is string && name.size() >= 2 && name.size() <= 80;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function userDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function roleFromProfile() {
      return isSignedIn() && userDoc().exists() ? userDoc().data.role : null;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.admin == true ||
        roleFromProfile() == 'admin'
      );
    }

    function isTeacherOrAdmin() {
      return isSignedIn() && (
        isAdmin() ||
        request.auth.token.teacher == true ||
        roleFromProfile() == 'teacher'
      );
    }

    function classTeacherUid(classId) {
      return classId is string
        && exists(/databases/$(database)/documents/classes/$(classId))
        ? get(/databases/$(database)/documents/classes/$(classId)).data.teacherUid
        : null;
    }

    function ownsClass(classId) {
      return isSignedIn() && classTeacherUid(classId) == request.auth.uid;
    }

    // Helper that resolves ownership of a meeting document.
    function ownsThisMeeting(meetingId) {
      let mtg = get(/databases/$(database)/documents/meetings/$(meetingId));
      return isSignedIn()
        && mtg.exists()
        && (
          // Modern documents: teacherUid stores the actual Firebase uid
          mtg.data.teacherUid == request.auth.uid
          // Legacy documents: teacherUid stores the display name — fall back
          || (mtg.data.classId is string && ownsClass(mtg.data.classId))
        );
    }

    // Default deny-all.
    match /{document=**} {
      allow read, write: if false;
    }

    // ── User profiles ────────────────────────────────────────────────────────
    match /users/{uid} {
      allow read: if isOwner(uid) || isAdmin();

      allow create: if isOwner(uid)
        && request.resource.data.uid == uid
        && request.resource.data.email is string
        && validFullName(request.resource.data.fullName)
        && request.resource.data.role == 'student'
        && request.resource.data.status == 'active';

      allow update: if isOwner(uid)
        && validFullName(request.resource.data.fullName)
        && request.resource.data.uid == resource.data.uid
        && request.resource.data.email == resource.data.email
        && !request.resource.data.diff(resource.data).changedKeys().hasAny([
          'role', 'status', 'approvedBy', 'approvedAt', 'isAdmin'
        ]);

      allow update, delete: if isAdmin();
    }

    // ── Role applications ────────────────────────────────────────────────────
    match /roleApplications/{appId} {
      allow create: if isSignedIn()
        && request.resource.data.ownerUid == request.auth.uid
        && request.resource.data.requestedRole in ['teacher', 'admin']
        && request.resource.data.status == 'pending';

      allow read: if isAdmin()
        || (isSignedIn() && resource.data.ownerUid == request.auth.uid);

      allow update, delete: if isAdmin();
    }

    // ── Classes ──────────────────────────────────────────────────────────────
    match /classes/{classId} {
      allow read: if isSignedIn();

      allow create: if isTeacherOrAdmin()
        || (isSignedIn() && request.resource.data.teacherUid == request.auth.uid);

      allow update, delete: if isTeacherOrAdmin()
        || (isSignedIn() && resource.data.teacherUid == request.auth.uid);

      match /enrollments/{enrollId} {
        allow read: if isTeacherOrAdmin()
          || (isSignedIn() && request.auth.uid == enrollId);
        allow create, update, delete: if isTeacherOrAdmin();
      }
    }

    // ── Meetings ─────────────────────────────────────────────────────────────
    match /meetings/{meetingId} {
      allow read: if isSignedIn();

      allow create: if isTeacherOrAdmin()
        || (isSignedIn() && request.resource.data.teacherUid == request.auth.uid);

      allow update, delete: if isTeacherOrAdmin()
        || (isSignedIn() && resource.data.teacherUid == request.auth.uid)
        || (isSignedIn() && ownsClass(resource.data.classId));

      // ── Attendance sub-collection ─────────────────────────────────────────
      match /attendance/{attendanceId} {
        allow read: if isTeacherOrAdmin()
          || (isSignedIn() && resource.data.studentUid == request.auth.uid);

        allow create, update: if isTeacherOrAdmin()
          || ownsThisMeeting(meetingId)
          || (isSignedIn() && resource.data.studentUid == request.auth.uid)
          || (isSignedIn() && request.resource.data.studentUid == request.auth.uid);

        allow delete: if isTeacherOrAdmin()
          || ownsThisMeeting(meetingId);
      }

      // ── Check-ins sub-collection ──────────────────────────────────────────
      match /checkIns/{uid} {
        allow read: if isTeacherOrAdmin() || isOwner(uid);
        allow create, update: if isOwner(uid) || isTeacherOrAdmin();
        allow delete: if isTeacherOrAdmin();
      }
    }

    // ── Root-level enrollments ────────────────────────────────────────────────
    match /enrollments/{enrollId} {
      allow read: if isAdmin()
        || (isSignedIn() && resource.data.teacherUid == request.auth.uid)
        || (isSignedIn() && ownsClass(resource.data.classId))
        || (isSignedIn() && resource.data.studentUid == request.auth.uid);

      allow create: if isTeacherOrAdmin()
        || (isSignedIn() && request.resource.data.teacherUid == request.auth.uid)
        || (isSignedIn()
          && request.resource.data.studentUid == request.auth.uid
          && request.resource.data.classId is string
          && classTeacherUid(request.resource.data.classId) != null
          && request.resource.data.teacherUid == classTeacherUid(request.resource.data.classId));

      allow update: if isTeacherOrAdmin()
        || (isSignedIn() && resource.data.teacherUid == request.auth.uid)
        || (isSignedIn() && ownsClass(resource.data.classId))
        || (isSignedIn()
          && resource.data.studentUid == request.auth.uid
          && request.resource.data.studentUid == resource.data.studentUid
          && request.resource.data.teacherUid == resource.data.teacherUid
          && request.resource.data.classId == resource.data.classId
          && request.resource.data.status == resource.data.status);

      // ── THIS IS THE FIX ──
      allow delete: if isTeacherOrAdmin()
        || (isSignedIn() && resource.data.teacherUid == request.auth.uid)
        || (isSignedIn() && ownsClass(resource.data.classId));
    }
  }
}